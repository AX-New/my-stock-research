# ============================================================
# 加密货币量化交易系统 - 环境配置
# 复制为 .env 并填写实际值
# ============================================================

# --- MySQL ---
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=stock_crypto

# --- Binance ---
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- OKX ---
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

# --- 默认交易所 (binance / okx) ---
CRYPTO_EXCHANGE=binance

# --- 默认交易对（逗号分隔）---
CRYPTO_SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT,BNB/USDT,XRP/USDT

# --- 默认K线周期（逗号分隔）---
CRYPTO_TIMEFRAMES=1h,4h,1d

# --- 全量同步天数（加密货币数据量小，默认10年全量）---
FULL_SYNC_DAYS=3650

# --- 网络代理（访问境外交易所）---
HTTP_PROXY=http://localhost:7890
HTTPS_PROXY=http://localhost:7890

# --- 服务端口 ---
API_PORT=8001

# --- 日志 ---
LOG_LEVEL=INFO
